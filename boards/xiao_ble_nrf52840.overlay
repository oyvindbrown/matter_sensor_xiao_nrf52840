/*
 * Adapted for Seeed Studio XIAO nRF52840 (non-Sense) Matter Contact Sensor
 * NCS SDK 3.2.x / UF2 bootloader via double-tap RST
 * Sources: Seeed Wiki, Zephyr xiao_ble, Nordic contact_sensor
 */

#include <zephyr/dt-bindings/led/led.h>
#include <samples/matter/nrf52_partitions.dtsi>

 / {
	chosen {
		nordic,pm-ext-flash = &p25q16h;
		zephyr,entropy = &rng;
	};

	/* Contact sensor (reed switch to D0/P0.02 + GND) */
	buttons {
		compatible = "gpio-keys";

		button1: button_1 {
			gpios = <&gpio0 2 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Contact Sensor";
		};
	};

	aliases {
		led0 = &led0;
		sw0 = &button1;
	};

	/* Flash partitions (UF2/MCUBoot compatible) */
	&flash0 {
		partitions {
			compatible = "fixed-partitions";
			#address-cells = <1>;
			#size-cells = <1>;

			mcuboot_partition: partition@0 {
				label = "mcuboot";
				reg = <0x0 0x10000>;
			};

			slot0_partition: partition@10000 {
				label = "image-0";
				reg = <0x10000 0x76000>;
			};

			slot1_partition: partition@86000 {
				label = "image-1";
				reg = <0x86000 0x74000>;
			};

			storage_partition: partition@f8000 {
				label = "storage";
				reg = <0xf8000 0x8000>;
			};
		};
	};

	/* Onboard LED (non-Sense RGB) */
	&led0 {
		gpios = <&gpio0 26 GPIO_ACTIVE_LOW>;  /* Red channel example */
	};
};

/* Disable unused for low power + UF2 stability */
&adc { status = "disabled"; };
&uart1 { status = "disabled"; };
&i2c0 { status = "disabled"; };
&spi1 { status = "disabled"; };
&spi3 { status = "disabled"; };
&pwm0 { status = "disabled"; };
&usbd { status = "okay"; };  /* Keep USB for UF2 */
